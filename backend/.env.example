# MongoDB connection string
# Get this from MongoDB Atlas: https://cloud.mongodb.com
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/cp-leaderboard

# Server port (optional, defaults to 3000)
PORT=3000

# Environment (development or production)
NODE_ENV=development

# Secret for cron job authentication
# Generate a random string: openssl rand -hex 32
CRON_SECRET=your-secure-random-string-here

# Secret for initial admin bootstrap (required for first setup)
# Generate a random string: openssl rand -hex 32
BOOTSTRAP_SECRET=your-bootstrap-secret-here

# Redis URL for distributed rate limiting (optional, falls back to in-memory)
# REDIS_URL=redis://localhost:6379

# Trust proxy setting for production behind reverse proxy (optional)
# Set to 1 or true when behind a load balancer / reverse proxy
# TRUST_PROXY=1

# Frontend URL for CORS (only needed in development)
FRONTEND_URL=http://localhost:5173
